{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(kill:*)",
      "Bash(find:*)",
      "Bash(npm run build:*)",
      "Bash(xargs:*)",
      "Bash(npm run db:push:*)",
      "Bash(npm run check:*)",
      "WebSearch",
      "WebFetch(domain:bolt.new)",
      "WebFetch(domain:replit.com)",
      "WebFetch(domain:www.emerge.haus)",
      "WebFetch(domain:fuselabcreative.com)",
      "WebFetch(domain:codewave.com)",
      "WebFetch(domain:matteing.com)",
      "Bash(npx tsc:*)",
      "Bash(grep:*)",
      "Bash(gh auth:*)",
      "Bash(git remote add:*)",
      "Bash(git push origin main feature/dashboard-overview-improvements replit-agent)",
      "Bash(npx vite build:*)",
      "Bash(dpkg -l)"
    ]
  },
  "enabledMcpjsonServers": [
    "stitch"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo -e '\\n\\033[42m\\033[30m  ✓ CLAUDE IS DONE  \\033[0m\\n'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo -e '\\n\\033[43m\\033[30m  ⚠ CLAUDE NEEDS INPUT  \\033[0m\\n'"
          }
        ]
      }
    ]
  }
}
