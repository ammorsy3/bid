{pkgs}: {
  deps = [
    pkgs.gh
    pkgs.haskellPackages.github
  ];
  shellHook = ''
    # Restore Claude auth from persistent workspace storage
    if [ -d "$HOME/workspace/.claude-data" ]; then
      rm -rf "$HOME/.claude"
      ln -sf "$HOME/workspace/.claude-data" "$HOME/.claude"
    fi
    if [ -f "$HOME/workspace/.claude-data.json" ]; then
      ln -sf "$HOME/workspace/.claude-data.json" "$HOME/.claude.json"
    fi
  '';
}
